{
  "UserPromptSubmit": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "node \"$HOME/.claude/booklib-suggest.js\""
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "WebFetch|WebSearch",
      "hooks": [
        {
          "type": "command",
          "command": "node \"${BOOKLIB_ROOT}/hooks/posttooluse-capture.mjs\""
        }
      ]
    }
  ]
}
